# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/debugbridge

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5174

# ── Rate limit ────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ── CLI ──────────────────────────────────────────────────────────────────────
DEBUGBRIDGE_API_URL=http://localhost:5000/api
DEBUGBRIDGE_TOKEN=
